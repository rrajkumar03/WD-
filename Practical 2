<!DOCTYPE html>
<html>
<head>
    <title>Image Hyperlink and Nested Table</title>
</head>
<body>

    <h1>Web Page Example</h1>

    <!-- Image -->
    <img src="https://via.placeholder.com/150" alt="Sample Image">

    <br><br>

    <!-- Hyperlink -->
    <a href="https://www.google.com">Visit Google</a>

    <br><br>

    <!-- Nested Table -->
    <table border="1" cellpadding="10">
        <tr>
            <th>Name</th>
            <th>Details</th>
        </tr>

        <tr>
            <td>Aryan</td>

            <td>
                <table border="1">
                    <tr>
                        <th>Age</th>
                        <th>City</th>
                    </tr>

                    <tr>
                        <td>18</td>
                        <td>Pune</td>
                    </tr>
                </table>
            </td>

        </tr>
    </table>

</body>
</html>
