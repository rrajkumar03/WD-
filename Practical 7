<!DOCTYPE html>
<html>
<head>
    <title>DOM Example</title>

    <script>
        function changeText()
        {
            document.getElementById("demo").innerHTML =
            "Welcome Aryan!";
        }
    </script>

</head>

<body>

    <h2 id="demo">
        Hello User
    </h2>

    <button onclick="changeText()">
        Click Here
    </button>

</body>
</html>
