<!DOCTYPE html>
<html>
<head>
    <title>CSS Example</title>

    <!-- Internal CSS -->
    <style>
        h1{
            color: blue;
        }

        table{
            border-collapse: collapse;
            width: 50%;
        }

        th, td{
            border: 1px solid black;
            padding: 10px;
            text-align: center;
        }
    </style>

    <!-- External CSS -->
    <link rel="stylesheet" href="style.css">

</head>
<body>

    <!-- Inline CSS -->
    <h1 style="background-color: yellow;">
        Student Details
    </h1>

    <table>
        <tr>
            <th>Name</th>
            <th>Marks</th>
        </tr>

        <tr>
            <td>Aryan</td>
            <td>90</td>
        </tr>

        <tr>
            <td>Rahul</td>
            <td>85</td>
        </tr>
    </table>

</body>
</html>
